{
  "expo": {
    "name": "Hazi",
    "slug": "hazi",
    "scheme": "hazi",
    "version": "0.1.0",
    "description": "Hazi trusted auctions, protected payments, and decluttering services.",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "updates": { "fallbackToCacheTimeout": 0 },
    "android": {
      "package": "ng.hazi.app",
      "versionCode": 1,
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"],
      "intentFilters": [{ "action": "VIEW", "autoVerify": false, "data": [{ "scheme": "hazi" }], "category": ["BROWSABLE", "DEFAULT"] }]
    },
    "ios": { "bundleIdentifier": "ng.hazi.app", "supportsTablet": false }
  }
}
